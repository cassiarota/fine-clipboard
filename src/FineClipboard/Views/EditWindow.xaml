<Window x:Class="FineClipboard.Views.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑后粘贴" Width="480" Height="340"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="#F4F4F6">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox x:Name="Editor" Grid.Row="0" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" FontSize="13" Padding="6" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" IsCancel="True" Width="84" Padding="0,5" />
            <Button Content="粘贴" IsDefault="True" Click="Ok_Click" Width="84" Padding="0,5" Margin="10,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
