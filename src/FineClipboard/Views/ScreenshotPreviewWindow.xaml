<Window x:Class="FineClipboard.Views.ScreenshotPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="截图编辑" Width="980" Height="720" MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen" Background="#7D7D7D"
        ResizeMode="CanResize" TextOptions.TextFormattingMode="Display" UseLayoutRounding="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="EditorTool" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/><Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="1,0"/><Setter Property="Padding" Value="7"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="ToolTipService.ShowDuration" Value="20000"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ToggleButton">
                <Border x:Name="Body" Background="{TemplateBinding Background}" BorderBrush="#2D7FE8" BorderThickness="0" CornerRadius="2">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Body" Property="Background" Value="#EAF2FC"/></Trigger>
                    <Trigger Property="IsChecked" Value="True"><Setter TargetName="Body" Property="Background" Value="#DCEBFC"/><Setter TargetName="Body" Property="BorderThickness" Value="0,0,0,2"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="EditorAction" TargetType="Button">
            <Setter Property="Width" Value="34"/><Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="1,0"/><Setter Property="Padding" Value="7"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="PopupChoice" TargetType="Button">
            <Setter Property="MinWidth" Value="80"/><Setter Property="Margin" Value="3"/><Setter Property="Padding" Value="9,6"/>
        </Style>
        <Style x:Key="IconPath" TargetType="Path">
            <Setter Property="Stroke" Value="#252A32"/><Setter Property="StrokeThickness" Value="1.7"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/><Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Stretch" Value="Uniform"/><Setter Property="Width" Value="18"/><Setter Property="Height" Value="18"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Border Background="#99000000" BorderBrush="#3388C7FF" BorderThickness="1" ClipToBounds="True">
            <Viewbox Stretch="Uniform">
                <Grid x:Name="EditorSurface" MouseLeftButtonDown="Editor_MouseLeftButtonDown"
                      MouseMove="Editor_MouseMove" MouseLeftButtonUp="Editor_MouseLeftButtonUp">
                    <Image x:Name="PreviewImage" Stretch="Fill"/>
                    <Canvas x:Name="AnnotationCanvas" Background="#01FFFFFF" ClipToBounds="True"/>
                </Grid>
            </Viewbox>
        </Border>

        <Border Grid.Row="1" HorizontalAlignment="Center" Margin="0,10,0,0" Background="#FAFFFFFF"
                BorderBrush="#2D7FE8" BorderThickness="1" Padding="5,3" SnapsToDevicePixels="True">
            <StackPanel Orientation="Horizontal">
                <Grid>
                    <ToggleButton x:Name="ShapeTool" Style="{StaticResource EditorTool}" Tag="shape" Checked="Tool_Checked" ToolTip="图形（点击右下角可选择形状）">
                        <Grid><Path Style="{StaticResource IconPath}" Data="M2,3 L13,3 L13,12 L2,12 Z M8,8 A5,4 0 1 0 18,8 A5,4 0 1 0 8,8"/><Path Data="M15,14 L19,14 L19,18" Stroke="#252A32" StrokeThickness="1"/></Grid>
                    </ToggleButton>
                    <Button Width="11" Height="11" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" BorderThickness="0" Padding="0" Click="ShapeMenu_Click"><Path Data="M1,2 L5,6 L9,2" Stroke="#252A32" StrokeThickness="1"/></Button>
                    <Popup x:Name="ShapePopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True"><Border Background="White" BorderBrush="#B8C3D0" BorderThickness="1" Padding="5"><StackPanel>
                        <Button Style="{StaticResource PopupChoice}" Content="矩形" Tag="rect" Click="ShapeChoice_Click"/>
                        <Button Style="{StaticResource PopupChoice}" Content="圆角矩形" Tag="roundedRect" Click="ShapeChoice_Click"/>
                        <Button Style="{StaticResource PopupChoice}" Content="椭圆" Tag="ellipse" Click="ShapeChoice_Click"/>
                    </StackPanel></Border></Popup>
                </Grid>
                <Grid>
                    <ToggleButton x:Name="LineTool" Style="{StaticResource EditorTool}" Tag="line" Checked="Tool_Checked" ToolTip="直线 / 箭头">
                        <Grid><Path Style="{StaticResource IconPath}" Data="M2,16 L16,2 M10,2 L16,2 L16,8"/></Grid>
                    </ToggleButton>
                    <Button Width="11" Height="11" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" BorderThickness="0" Padding="0" Click="LineMenu_Click"><Path Data="M1,2 L5,6 L9,2" Stroke="#252A32" StrokeThickness="1"/></Button>
                    <Popup x:Name="LinePopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True"><Border Background="White" BorderBrush="#B8C3D0" BorderThickness="1" Padding="5"><StackPanel>
                        <Button Style="{StaticResource PopupChoice}" Content="直线" Tag="line" Click="LineChoice_Click"/>
                        <Button Style="{StaticResource PopupChoice}" Content="箭头" Tag="arrow" Click="LineChoice_Click"/>
                    </StackPanel></Border></Popup>
                </Grid>
                <Grid>
                    <ToggleButton x:Name="ColorTool" Style="{StaticResource EditorTool}" ToolTip="颜色" Click="ColorMenu_Click">
                        <Grid><Path Style="{StaticResource IconPath}" Data="M3,15 L6,15 L16,5 L13,2 L3,12 Z M11,4 L14,7"/><Ellipse x:Name="CurrentColorDot" Width="5" Height="5" Fill="#F5222D" HorizontalAlignment="Right" VerticalAlignment="Top"/></Grid>
                    </ToggleButton>
                    <Popup x:Name="ColorPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True"><Border Background="White" BorderBrush="#B8C3D0" BorderThickness="1" Padding="7"><WrapPanel Width="112">
                        <Button Tag="#F5222D" Click="ColorChoice_Click" Background="#F5222D" Width="24" Height="24" Margin="2" Padding="0"/>
                        <Button Tag="#FA8C16" Click="ColorChoice_Click" Background="#FA8C16" Width="24" Height="24" Margin="2" Padding="0"/>
                        <Button Tag="#FADB14" Click="ColorChoice_Click" Background="#FADB14" Width="24" Height="24" Margin="2" Padding="0"/>
                        <Button Tag="#52C41A" Click="ColorChoice_Click" Background="#52C41A" Width="24" Height="24" Margin="2" Padding="0"/>
                        <Button Tag="#1677FF" Click="ColorChoice_Click" Background="#1677FF" Width="24" Height="24" Margin="2" Padding="0"/>
                        <Button Tag="#722ED1" Click="ColorChoice_Click" Background="#722ED1" Width="24" Height="24" Margin="2" Padding="0"/>
                        <Button Tag="#FFFFFF" Click="ColorChoice_Click" Background="#FFFFFF" Width="24" Height="24" Margin="2" Padding="0"/>
                        <Button Tag="#111111" Click="ColorChoice_Click" Background="#111111" Width="24" Height="24" Margin="2" Padding="0"/>
                    </WrapPanel></Border></Popup>
                </Grid>
                <Grid>
                    <ToggleButton x:Name="PenTool" Style="{StaticResource EditorTool}" Tag="pen" Checked="Tool_Checked" ToolTip="画笔（粗细与形状）"><Path Style="{StaticResource IconPath}" Data="M3,15 C6,11 10,6 15,2 C17,1 18,3 17,5 C13,10 9,14 5,17 Z M3,15 L2,18 L5,17"/></ToggleButton>
                    <Button Width="11" Height="11" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" BorderThickness="0" Padding="0" Click="PenMenu_Click"><Path Data="M1,2 L5,6 L9,2" Stroke="#252A32" StrokeThickness="1"/></Button>
                    <Popup x:Name="PenPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True"><Border Background="White" BorderBrush="#B8C3D0" BorderThickness="1" Padding="7"><StackPanel>
                        <TextBlock Text="粗细" Margin="4,2" Foreground="#5B6470"/><StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PopupChoice}" MinWidth="44" Content="细" Tag="2" Click="PenWidth_Click"/>
                            <Button Style="{StaticResource PopupChoice}" MinWidth="44" Content="中" Tag="5" Click="PenWidth_Click"/>
                            <Button Style="{StaticResource PopupChoice}" MinWidth="44" Content="粗" Tag="10" Click="PenWidth_Click"/>
                        </StackPanel><TextBlock Text="笔头" Margin="4,7,4,2" Foreground="#5B6470"/><StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PopupChoice}" Content="圆头" Tag="round" Click="PenShape_Click"/>
                            <Button Style="{StaticResource PopupChoice}" Content="方头" Tag="square" Click="PenShape_Click"/>
                        </StackPanel>
                    </StackPanel></Border></Popup>
                </Grid>
                <ToggleButton x:Name="MosaicTool" Style="{StaticResource EditorTool}" Tag="mosaic" Checked="Tool_Checked" ToolTip="马赛克"><Path Style="{StaticResource IconPath}" Data="M2,2 L8,2 L8,8 L2,8 Z M10,2 L16,2 L16,8 L10,8 Z M2,10 L8,10 L8,16 L2,16 Z M10,10 L16,10 L16,16 L10,16 Z"/></ToggleButton>
                <ToggleButton x:Name="TextTool" Style="{StaticResource EditorTool}" Tag="text" Checked="Tool_Checked" ToolTip="插入文字"><Path Style="{StaticResource IconPath}" Data="M3,3 L15,3 M9,3 L9,16 M5,16 L13,16"/></ToggleButton>
                <ToggleButton x:Name="EraserTool" Style="{StaticResource EditorTool}" Tag="eraser" Checked="Tool_Checked" ToolTip="橡皮（单击标注删除）"><Path Style="{StaticResource IconPath}" Data="M3,12 L11,3 Q12,2 13,3 L17,7 Q18,8 17,9 L10,16 L6,16 L3,13 Z M7,16 L13,10"/></ToggleButton>
                <Border Width="1" Height="22" Background="#C9CED5" Margin="4,5"/>
                <Button x:Name="UndoButton" Style="{StaticResource EditorAction}" Click="Undo_Click" ToolTip="撤销 (Ctrl+Z)"><Path Style="{StaticResource IconPath}" Data="M7,5 L2,9 L7,13 M3,9 L10,9 C15,9 17,12 17,17"/></Button>
                <Button x:Name="RedoButton" Style="{StaticResource EditorAction}" Click="Redo_Click" ToolTip="重做 (Ctrl+Y)"><Path Style="{StaticResource IconPath}" Data="M11,5 L16,9 L11,13 M15,9 L8,9 C3,9 1,12 1,17"/></Button>
                <Button Style="{StaticResource EditorAction}" Click="Save_Click" ToolTip="保存 (Ctrl+S)"><Path Style="{StaticResource IconPath}" Data="M3,2 L15,2 L18,5 L18,18 L2,18 L2,2 Z M6,2 L6,8 L14,8 L14,2 M6,18 L6,12 L14,12 L14,18"/></Button>
                <Button Style="{StaticResource EditorAction}" Click="Copy_Click" ToolTip="复制 (Ctrl+C)"><Path Style="{StaticResource IconPath}" Data="M6,5 L17,5 L17,18 L6,18 Z M3,15 L2,15 L2,2 L13,2 L13,5"/></Button>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" x:Name="Hint" HorizontalAlignment="Center" Margin="4,7,4,0" Foreground="#F4F4F4"
                   Text="选择工具后在图片上拖动；工具右下角可切换类型。"/>
    </Grid>
</Window>
