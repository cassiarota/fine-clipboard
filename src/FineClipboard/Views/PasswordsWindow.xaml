<Window x:Class="FineClipboard.Views.PasswordsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="密码管理" Width="600" Height="420"
        WindowStartupLocation="CenterScreen" Background="#F4F4F6">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="密码列表" FontWeight="Bold" Foreground="#222" Margin="0,0,0,6" />
            <Button DockPanel.Dock="Bottom" Content="＋ 新建" Click="New_Click" Padding="0,6" Margin="0,8,0,0" />
            <ListBox x:Name="List" DisplayMemberPath="Name" SelectionChanged="List_SelectionChanged" />
        </DockPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="名称 / 用途" Foreground="#444" Margin="0,0,0,4" />
            <TextBox x:Name="NameBox" Grid.Row="1" Padding="6,4" FontSize="13" />

            <DockPanel Grid.Row="2" Margin="0,12,0,4">
                <CheckBox x:Name="ShowCheck" DockPanel.Dock="Right" Content="显示" Click="ShowCheck_Click" />
                <TextBlock Text="密码" Foreground="#444" />
            </DockPanel>
            <Grid Grid.Row="3">
                <PasswordBox x:Name="SecretBox" Padding="6,4" FontSize="13" />
                <TextBox x:Name="SecretText" Padding="6,4" FontSize="13" Visibility="Collapsed" />
            </Grid>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="删除" Click="Delete_Click" Width="84" Padding="0,5" Margin="0,0,10,0" />
                <Button Content="保存" Click="Save_Click" Width="84" Padding="0,5" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
